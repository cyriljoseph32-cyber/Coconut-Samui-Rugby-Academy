---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
import PalmSilhouette from "../components/PalmSilhouette.astro";
import { SITE } from "../config/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "ImageGallery",
    name: "Coconut Samui Rugby Academy Gallery",
    url: "https://coconutsamuirugby.com/gallery/",
  },
];

// Branded art tiles until real photography lands — swap each for an <img>
// (AVIF/WebP, width/height, loading="lazy") keeping the same label + span.
const tiles = [
  { label: "Saturday training", tone: "ink", span: "sm:col-span-2 sm:row-span-2" },
  { label: "Tag rugby", tone: "palm", span: "" },
  { label: "Sunset touch", tone: "clay", span: "" },
  { label: "Holiday camps", tone: "sand", span: "sm:col-span-2" },
  { label: "Team huddles", tone: "palm", span: "" },
  { label: "Match days", tone: "ink", span: "" },
];

const toneClass: Record<string, string> = {
  ink: "bg-ink text-paper",
  palm: "bg-palm text-paper",
  clay: "bg-clay text-chalk",
  sand: "bg-sand-deep text-ink",
};
---

<Base
  title="Gallery | Coconut Samui Rugby Academy"
  description="Training days, camps and match moments from Koh Samui's rugby community."
  schema={schema}
>
  <section class="mx-auto max-w-[1240px] px-5 pt-14 pb-6 sm:px-8 lg:pt-20">
    <div class="grid gap-x-16 gap-y-8 lg:grid-cols-12">
      <div class="lg:col-span-8" data-reveal>
        <p class="kicker">Gallery</p>
        <h1 class="display-xl mt-6">Life at the<br />academy.</h1>
      </div>
      <p class="self-end text-lg leading-relaxed text-ink/70 lg:col-span-4" data-reveal data-reveal-delay="100ms">
        We're a young academy and proud of it. This page fills with real training days, camps and
        match moments as they happen — no stock photos, ever. Instagram gets them first.
      </p>
    </div>
    <div class="mt-8" data-reveal><Button href={SITE.instagram} target="_blank" rel="noopener">Follow {SITE.instagramHandle}</Button></div>
  </section>

  <section class="mx-auto max-w-[1240px] px-5 py-14 sm:px-8">
    <ul class="grid auto-rows-[180px] grid-cols-2 gap-4 sm:grid-cols-4">
      {
        tiles.map((t) => (
          <li class={`group relative overflow-hidden rounded-xl grain ${toneClass[t.tone]} ${t.span}`} data-reveal>
            <PalmSilhouette class="pointer-events-none absolute -right-6 -bottom-8 h-40 w-40 opacity-15 transition-transform duration-500 group-hover:scale-110" />
            <div class="relative flex h-full flex-col justify-between p-5">
              <span class="font-body text-[0.7rem] font-semibold uppercase tracking-[0.18em] opacity-70">Coming soon</span>
              <span class="font-display text-xl leading-tight">{t.label}</span>
            </div>
          </li>
        ))
      }
    </ul>
    <p class="mt-10 max-w-2xl text-sm leading-relaxed text-ink/55">
      Parents: photos of your kids are only ever published with your written consent — it's part of
      our safeguarding policy.
    </p>
  </section>
</Base>
