---
import Base from "../layouts/Base.astro";
import Wave from "../components/Wave.astro";
import Button from "../components/Button.astro";
import LogoMark from "../components/LogoMark.astro";
import { SITE } from "../config/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "ImageGallery",
    name: "Coconut Samui Rugby Academy Gallery",
    url: "https://coconutsamuirugby.com/gallery/",
  },
];

// Placeholder tiles — swap each for a real <img> (AVIF/WebP, width/height set,
// loading="lazy") as academy photography comes in. Keep the alt text pattern.
const placeholders = [
  { label: "Saturday training", note: "Kids session, first photos coming after launch" },
  { label: "Tag rugby matches", note: "Match-day moments" },
  { label: "Teens contact skills", note: "Progressive contact training" },
  { label: "Sunset touch rugby", note: "Adult sessions on the island" },
  { label: "Holiday camps", note: "Camp week highlights" },
  { label: "Team huddles", note: "Where every session ends" },
];
---

<Base
  title="Gallery | Coconut Samui Rugby Academy"
  description="Training days, camps and match moments from Koh Samui's rugby community."
  schema={schema}
>
  <section class="bg-shell">
    <div class="mx-auto max-w-[1200px] px-4 pb-14 pt-14 sm:px-6 lg:pt-20">
      <p class="font-display text-sm font-bold tracking-[0.25em] text-amber-dark uppercase">Gallery</p>
      <h1 class="mt-3 text-4xl leading-tight text-palm sm:text-5xl">Life at the Academy</h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-jungle/80">
        We're a young academy and proud of it — this page fills with real training days, camps and
        match moments as they happen. No stock photos, ever. For the live feed, Instagram is where
        it all lands first.
      </p>
      <div class="mt-8">
        <Button href={SITE.instagram}>Follow on Instagram</Button>
      </div>
    </div>
  </section>
  <Wave fill="var(--color-shell)" flip />

  <section class="mx-auto max-w-[1200px] px-4 py-16 sm:px-6 lg:py-20">
    <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        placeholders.map((tile) => (
          <li class="flex aspect-[4/3] flex-col items-center justify-center gap-3 rounded-3xl border-2 border-dashed border-sand bg-shell/60 p-6 text-center">
            <LogoMark class="h-12 w-12 text-palm/40" accent="transparent" />
            <p class="font-display font-bold text-palm">{tile.label}</p>
            <p class="text-xs text-jungle/50">{tile.note}</p>
          </li>
        ))
      }
    </ul>
    <p class="mt-10 text-center text-sm text-jungle/60">
      Parents: photos of your kids are only ever published with your written consent — it's part of
      our safeguarding policy.
    </p>
  </section>
</Base>
