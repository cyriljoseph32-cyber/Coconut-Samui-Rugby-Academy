---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
import Logo from "../components/Logo.astro";
import PalmSilhouette from "../components/PalmSilhouette.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    name: "About Coconut Samui Rugby Academy",
    url: "https://coconutsamuirugby.com/about/",
  },
];

const values = [
  ["Respect", "Players shake hands with the opposition and thank the ref — win or lose, age four or fourteen."],
  ["Discipline", "Boots on, on time, kit ready. Kids own their preparation; parents tell us it follows them home."],
  ["Inclusion", "Scholarship spots for local kids, mixed Thai–expat squads, and no bench-warmers. Ever."],
  ["Team spirit", "Every session ends in a huddle. Every try is celebrated by the whole side, not one player."],
];

const safety = [
  "Tag-only rugby under age 10 — no contact, no exceptions",
  "Progressive contact for teens per World Rugby age-grade guidelines",
  "First-aid trained coach at every session",
  "Background-checked staff and a written child-safeguarding policy",
  "Hydration and sun-safety breaks built into every island session",
];
---

<Base
  title="About Us | Coconut Samui Rugby Academy — Our Mission & Coaches"
  description="Founded to bring structured rugby to Koh Samui. Meet our coaches, our values and our 2027 vision: 30+ kids, 2 camps, 1 inter-school tournament."
  schema={schema}
>
  <!-- Hero -->
  <section class="mx-auto max-w-[1240px] px-5 pt-14 pb-4 sm:px-8 lg:pt-20">
    <div class="grid gap-x-16 gap-y-8 lg:grid-cols-12">
      <div class="lg:col-span-8" data-reveal>
        <p class="kicker">About &amp; Mission</p>
        <h1 class="display-xl mt-6">The first rugby<br />academy on Samui.</h1>
      </div>
      <p class="self-end text-lg leading-relaxed text-ink/70 lg:col-span-4" data-reveal data-reveal-delay="100ms">
        We exist to give island kids a real team sport — one that teaches respect and belonging as
        seriously as it teaches passing and tackling.
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="mx-auto max-w-[1240px] px-5 py-16 sm:px-8 lg:py-24">
    <div class="grid gap-x-16 gap-y-10 lg:grid-cols-12">
      <div class="lg:col-span-4" data-reveal>
        <p class="kicker">The story</p>
        <h2 class="display-lg mt-5">Why rugby,<br />why here.</h2>
      </div>
      <div class="space-y-5 text-lg leading-relaxed text-ink/75 lg:col-span-7 lg:col-start-6" data-reveal data-reveal-delay="100ms">
        <p>
          Families on Samui — Thai and expat alike — kept asking the same question: where can my
          child play a real team sport, with real structure, in a language they understand?
        </p>
        <p class="text-ink/65">
          Football exists, Muay Thai is everywhere. But rugby offers something neither can: a sport
          where every body type has a position, where respect for the referee is non-negotiable, and
          where the culture off the pitch matters as much as the score on it.
        </p>
        <p class="text-ink/65">
          So we built the academy the island was missing — an age-based curriculum from tag rugby at
          four to a full contact pathway for teens, coached in French and English, with safety
          standards set by World Rugby's age-grade guidelines, and one hard rule: every child gets
          game time, every session.
        </p>
      </div>
    </div>
  </section>

  <!-- Values — ink band -->
  <section class="relative overflow-hidden border-y border-ink/12 bg-ink text-paper">
    <PalmSilhouette class="pointer-events-none absolute -right-16 -bottom-10 h-80 w-80 text-fern/12" />
    <div class="relative mx-auto max-w-[1240px] px-5 py-20 sm:px-8 lg:py-24">
      <h2 class="display-lg max-w-xl text-paper" data-reveal>What our values look like in practice.</h2>
      <dl class="mt-14 grid gap-x-14 gap-y-9 sm:grid-cols-2">
        {
          values.map(([name, def], i) => (
            <div class="border-t border-paper/15 pt-5" data-reveal data-reveal-delay={`${i * 70}ms`}>
              <dt class="font-display text-2xl text-paper">{name}</dt>
              <dd class="mt-2 leading-relaxed text-paper/70">{def}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- Vision -->
  <section class="mx-auto max-w-[1240px] px-5 py-20 sm:px-8 lg:py-24">
    <p class="kicker" data-reveal>Vision 2027</p>
    <div class="mt-8 grid gap-px overflow-hidden rounded-xl border border-ink/12 bg-ink/12 sm:grid-cols-3">
      {
        [["30+", "kids enrolled by end of 2027"], ["2", "intensive holiday camps a year"], ["1", "inter-school tournament — the island's first"]].map(([s, l], i) => (
          <div class="bg-paper p-8" data-reveal data-reveal-delay={`${i * 90}ms`}>
            <p class="font-display text-6xl text-palm">{s}</p>
            <p class="mt-3 text-sm leading-relaxed text-ink/65">{l}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Coaches + safety -->
  <section class="mx-auto max-w-[1240px] px-5 pb-24 sm:px-8">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-7" data-reveal>
        <p class="kicker">On the whistle</p>
        <h2 class="display-lg mt-5">Coaching you can trust with your kids.</h2>
        <p class="mt-5 max-w-xl leading-relaxed text-ink/70">
          Sessions are led by experienced rugby coaches with age-grade backgrounds, first-aid
          certification and background checks. Full coach profiles land here as the team grows.
        </p>
        <ul class="mt-8 space-y-3">
          {
            safety.map((s) => (
              <li class="flex gap-3 border-t border-ink/12 pt-3 text-ink/75">
                <svg viewBox="0 0 24 24" class="mt-1 h-4 w-4 shrink-0 text-clay-deep" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                {s}
              </li>
            ))
          }
        </ul>
        <div class="mt-9">
          <Button href="/contact/">Meet us at a session</Button>
        </div>
      </div>
      <div class="lg:col-span-4 lg:col-start-9" data-reveal data-reveal-delay="120ms">
        <div class="flex flex-col items-center rounded-xl border border-ink/12 bg-sand/50 p-10 text-center">
          <Logo variant="monogram" class="h-44 text-palm" />
          <p class="mt-5 max-w-xs text-sm leading-relaxed text-ink/65">
            The CSRA crest — worn on every academy jersey, earned by every player.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>
