---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
import LogoMark from "../components/LogoMark.astro";
---

<Base title="Page not found | Coconut Samui Rugby Academy" description="That page went into touch. Head back to the academy homepage.">
  <section class="mx-auto flex max-w-[1240px] flex-col items-start px-5 py-28 sm:px-8">
    <LogoMark class="h-16 w-16 text-palm" seam="var(--color-paper)" />
    <p class="kicker mt-8">Error 404</p>
    <h1 class="display-xl mt-4">Into touch.</h1>
    <p class="mt-5 max-w-md text-lg leading-relaxed text-ink/70">
      That page is out of play. Let's restart with a lineout — back to the homepage, or straight to
      a free trial.
    </p>
    <div class="mt-9 flex flex-wrap gap-4">
      <Button href="/">Back to home</Button>
      <Button href="/contact/" variant="outline">Book a free trial</Button>
    </div>
  </section>
</Base>
