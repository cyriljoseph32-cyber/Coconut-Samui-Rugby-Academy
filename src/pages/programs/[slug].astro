---
import Base from "../../layouts/Base.astro";
import Button from "../../components/Button.astro";
import FAQ from "../../components/FAQ.astro";
import { programs } from "../../data/programs";
import { courseSchema, faqSchema } from "../../lib/schema";
import { waLink } from "../../config/site";

export function getStaticPaths() {
  return programs.map((program) => ({ params: { slug: program.slug }, props: { program } }));
}

const { program } = Astro.props;
const others = programs.filter((p) => p.slug !== program.slug);
const idx = programs.findIndex((p) => p.slug === program.slug) + 1;
const schema = [
  courseSchema({ name: program.name, description: program.short, url: `/programs/${program.slug}/` }),
  faqSchema(program.faq),
];
---

<Base
  title={program.seoTitle}
  description={program.seoDescription}
  schema={schema}
  whatsappMessage={program.cta.whatsapp}
>
  <!-- Hero -->
  <section class="border-b border-ink/12">
    <div class="mx-auto max-w-[1240px] px-5 pt-10 pb-16 sm:px-8 lg:pt-16">
      <nav class="text-sm text-ink/55" aria-label="Breadcrumb">
        <a href="/programs/" class="link-underline hover:text-ink">Programs</a>
        <span aria-hidden="true"> / </span>
        <span class="text-ink/80">{program.name}</span>
      </nav>
      <div class="mt-8 grid gap-x-16 gap-y-8 lg:grid-cols-12">
        <div class="lg:col-span-7" data-reveal>
          <p class="kicker">0{idx} — {program.ages} · {program.tag}</p>
          <h1 class="display-xl mt-6">{program.h1}</h1>
        </div>
        <div class="self-end lg:col-span-5" data-reveal data-reveal-delay="100ms">
          <p class="text-lg leading-relaxed text-ink/75">{program.intro}</p>
          <div class="mt-8 flex flex-wrap gap-4">
            <Button href="/contact/">{program.cta.label}</Button>
            <Button href={waLink(program.cta.whatsapp)} variant="outline">WhatsApp us</Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Session + details -->
  <section class="mx-auto max-w-[1240px] px-5 py-16 sm:px-8 lg:py-24">
    <div class="grid gap-x-16 gap-y-12 lg:grid-cols-12">
      <div class="lg:col-span-7" data-reveal>
        <p class="kicker">On the pitch</p>
        <h2 class="display-lg mt-4">What a session looks like</h2>
        <ol class="mt-8 border-t border-ink/12">
          {
            program.sessionLooksLike.map((step, i) => (
              <li class="flex items-baseline gap-5 border-b border-ink/12 py-4">
                <span class="font-body text-sm font-semibold text-clay-deep tabular-nums">0{i + 1}</span>
                <span class="text-lg text-ink/80">{step}</span>
              </li>
            ))
          }
        </ol>
      </div>
      <div class="lg:col-span-4 lg:col-start-9" data-reveal data-reveal-delay="100ms">
        <div class="rounded-xl border border-ink/12 bg-sand/50 p-7">
          <p class="kicker">Good to know</p>
          <dl class="mt-5 divide-y divide-ink/10">
            {
              program.details.map((d) => (
                <div class="grid gap-0.5 py-3">
                  <dt class="font-display text-base text-palm">{d.label}</dt>
                  <dd class="text-sm leading-relaxed text-ink/70">{d.value}</dd>
                </div>
              ))
            }
          </dl>
        </div>
        <p class="mt-4 px-1 text-sm text-ink/55">
          Schedule and pricing are confirmed on WhatsApp — sessions follow school terms and island
          weather.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-ink/12 bg-sand/40">
    <div class="mx-auto max-w-[1240px] px-5 py-16 sm:px-8 lg:py-24">
      <div class="grid gap-x-16 gap-y-8 lg:grid-cols-12">
        <div class="lg:col-span-4" data-reveal>
          <p class="kicker">Questions parents ask</p>
          <h2 class="display-lg mt-4">Straight answers</h2>
        </div>
        <div class="lg:col-span-7 lg:col-start-6" data-reveal data-reveal-delay="100ms">
          <FAQ items={program.faq} />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA + other programs -->
  <section class="mx-auto max-w-[1240px] px-5 py-16 sm:px-8 lg:py-24">
    <div class="relative overflow-hidden rounded-xl bg-palm px-6 py-12 text-paper sm:px-12 grain" data-reveal>
      <div class="relative flex flex-wrap items-center justify-between gap-6">
        <div>
          <h2 class="display-lg text-paper">Ready when you are.</h2>
          <p class="mt-3 max-w-md text-paper/80">{program.cta.label} — or just come watch a session first. No pressure, no paperwork.</p>
        </div>
        <Button href="/contact/" variant="paper">{program.cta.label}</Button>
      </div>
    </div>

    <div class="mt-14">
      <p class="kicker" data-reveal>Other programs</p>
      <div class="mt-5 grid gap-4 sm:grid-cols-3">
        {
          others.map((p) => (
            <a href={`/programs/${p.slug}/`} class="group rounded-xl border border-ink/12 p-6 transition-colors hover:border-ink/40" data-reveal>
              <p class="text-xs font-medium text-ink/55">{p.ages}</p>
              <p class="mt-1 font-display text-xl transition-colors group-hover:text-palm">{p.name}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Base>
