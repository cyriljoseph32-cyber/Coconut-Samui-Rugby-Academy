---
import Base from "../../layouts/Base.astro";
import Wave from "../../components/Wave.astro";
import Button from "../../components/Button.astro";
import FAQ from "../../components/FAQ.astro";
import SectionHead from "../../components/SectionHead.astro";
import { programs } from "../../data/programs";
import { courseSchema, faqSchema } from "../../lib/schema";
import { waLink } from "../../config/site";

export function getStaticPaths() {
  return programs.map((program) => ({ params: { slug: program.slug }, props: { program } }));
}

const { program } = Astro.props;
const others = programs.filter((p) => p.slug !== program.slug);
const schema = [
  courseSchema({ name: program.name, description: program.short, url: `/programs/${program.slug}/` }),
  faqSchema(program.faq),
];
---

<Base
  title={program.seoTitle}
  description={program.seoDescription}
  schema={schema}
  whatsappMessage={program.cta.whatsapp}
>
  <section class="bg-shell">
    <div class="mx-auto max-w-[1200px] px-4 pb-14 pt-14 sm:px-6 lg:pt-20">
      <nav class="text-sm text-jungle/60" aria-label="Breadcrumb">
        <a href="/programs/" class="hover:text-palm hover:underline">Programs</a>
        <span aria-hidden="true"> / </span>
        <span class="text-jungle">{program.name}</span>
      </nav>
      <p class="mt-6 font-display text-sm font-bold tracking-[0.25em] text-amber-dark uppercase">
        {program.ages} · {program.tag}
      </p>
      <h1 class="mt-3 max-w-3xl text-4xl leading-tight text-palm sm:text-5xl">{program.h1}</h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-jungle/80">{program.intro}</p>
      <div class="mt-8 flex flex-wrap gap-4">
        <Button href="/contact/">{program.cta.label}</Button>
        <Button href={waLink(program.cta.whatsapp)} variant="secondary">WhatsApp us</Button>
      </div>
    </div>
  </section>
  <Wave fill="var(--color-shell)" flip />

  <section class="mx-auto max-w-[1200px] px-4 py-16 sm:px-6 lg:py-20">
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <SectionHead eyebrow="On the pitch" title="What a session looks like" align="left" />
        <ol class="mt-6 space-y-4">
          {
            program.sessionLooksLike.map((step, i) => (
              <li class="flex items-start gap-4 rounded-2xl border border-sand bg-white p-5">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-palm font-display font-bold text-white">
                  {i + 1}
                </span>
                <span class="pt-1.5 text-jungle/85">{step}</span>
              </li>
            ))
          }
        </ol>
      </div>
      <div>
        <SectionHead eyebrow="The details" title="Good to know" align="left" />
        <dl class="mt-6 divide-y divide-sand rounded-2xl border border-sand bg-shell/50">
          {
            program.details.map((d) => (
              <div class="grid gap-1 px-6 py-4 sm:grid-cols-[140px_1fr]">
                <dt class="font-display text-sm font-bold text-palm">{d.label}</dt>
                <dd class="text-sm leading-relaxed text-jungle/80">{d.value}</dd>
              </div>
            ))
          }
        </dl>
        <p class="mt-4 text-sm text-jungle/60">
          Schedule and pricing are confirmed on WhatsApp — sessions move with island weather and
          school terms.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-shell">
    <div class="mx-auto max-w-[1200px] px-4 py-16 sm:px-6">
      <SectionHead eyebrow="Questions parents ask" title="FAQ" />
      <FAQ items={program.faq} class="mx-auto mt-10 max-w-3xl" />
    </div>
  </section>

  <section class="mx-auto max-w-[1200px] px-4 py-16 sm:px-6">
    <div class="rounded-3xl bg-palm p-8 text-center text-white sm:p-12">
      <h2 class="text-2xl sm:text-3xl">Ready when you are</h2>
      <p class="mx-auto mt-3 max-w-xl text-sand">
        {program.cta.label} — or just come watch a session first. No pressure, no paperwork.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-4">
        <Button href="/contact/">{program.cta.label}</Button>
      </div>
    </div>

    <div class="mt-14">
      <h2 class="font-display text-sm font-bold tracking-[0.25em] text-amber-dark uppercase">
        Other programs
      </h2>
      <div class="mt-5 grid gap-4 sm:grid-cols-3">
        {
          others.map((p) => (
            <a
              href={`/programs/${p.slug}/`}
              class="rounded-2xl border border-sand p-5 transition-colors hover:border-palm"
            >
              <p class="text-xs font-semibold text-jungle/60">{p.ages}</p>
              <p class="mt-1 font-display font-bold text-palm">{p.name}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Base>
