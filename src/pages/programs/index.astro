---
import Base from "../../layouts/Base.astro";
import Button from "../../components/Button.astro";
import { programs } from "../../data/programs";
import { courseSchema } from "../../lib/schema";

const schema = programs.map((p) =>
  courseSchema({ name: p.name, description: p.short, url: `/programs/${p.slug}/` })
);
---

<Base
  title="Rugby Programs Koh Samui | Kids 4–10, Teens, Adults, Corporate"
  description="Age-based rugby training on Koh Samui: fun-first for ages 4–10, competitive pathway for teens, social touch rugby for adults, team-building for companies."
  schema={schema}
>
  <section class="mx-auto max-w-[1240px] px-5 pt-14 pb-6 sm:px-8 lg:pt-20">
    <div class="grid gap-x-16 gap-y-8 lg:grid-cols-12">
      <div class="lg:col-span-8" data-reveal>
        <p class="kicker">Programs</p>
        <h1 class="display-xl mt-6">Everyone plays.<br />Everyone belongs.</h1>
      </div>
      <p class="self-end text-lg leading-relaxed text-ink/70 lg:col-span-4" data-reveal data-reveal-delay="100ms">
        Four programs, one philosophy. Pick the one that fits — the first session is always free for
        kids and teens.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-[1240px] px-5 pb-16 sm:px-8">
    <div class="border-t border-ink/15">
      {
        programs.map((p, i) => (
          <article class="group border-b border-ink/15" data-reveal>
            <a href={`/programs/${p.slug}/`} class="grid gap-x-10 gap-y-4 py-10 lg:grid-cols-12">
              <div class="flex items-baseline gap-4 lg:col-span-4">
                <span class="font-body text-sm font-semibold text-clay-deep tabular-nums">0{i + 1}</span>
                <div>
                  <h2 class="font-display text-3xl transition-colors group-hover:text-palm sm:text-4xl">{p.name}</h2>
                  <p class="mt-2 text-sm font-medium text-ink/55">{p.ages} · {p.tag}</p>
                </div>
              </div>
              <div class="lg:col-span-6">
                <p class="max-w-xl leading-relaxed text-ink/70">{p.short}</p>
                <dl class="mt-4 flex flex-wrap gap-x-8 gap-y-1 text-sm text-ink/60">
                  {p.details.slice(0, 2).map((d) => (
                    <div class="flex gap-2"><dt class="font-semibold text-ink/80">{d.label}:</dt><dd>{d.value}</dd></div>
                  ))}
                </dl>
              </div>
              <div class="flex items-center lg:col-span-2 lg:justify-end">
                <span class="link-underline inline-flex items-center gap-2 font-body font-semibold text-ink">
                  Details
                  <svg viewBox="0 0 24 24" class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </span>
              </div>
            </a>
          </article>
        ))
      }
    </div>

    <div class="relative mt-16 overflow-hidden rounded-xl bg-ink px-6 py-14 text-paper sm:px-14 grain" data-reveal>
      <div class="relative grid gap-6 lg:grid-cols-[1.4fr_auto] lg:items-center">
        <div>
          <h2 class="display-lg text-paper">Not sure which fits?</h2>
          <p class="mt-4 max-w-lg leading-relaxed text-paper/75">
            Tell us your child's age and experience on WhatsApp — we'll point you to the right session
            and hold a free trial spot.
          </p>
        </div>
        <Button href="/contact/" variant="paper">Book a free trial</Button>
      </div>
    </div>
  </section>
</Base>
