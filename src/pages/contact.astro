---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
import FAQ from "../components/FAQ.astro";
import { SITE, FORM_ENDPOINT, waLink } from "../config/site";
import { faqSchema } from "../lib/schema";

const faq = [
  { q: "How fast do you reply?", a: "Within 24 hours by email, usually much faster on WhatsApp." },
  { q: "What does the free trial include?", a: "One full session with the right age group — no payment details, no obligation. Bring water, trainers and sunscreen; we provide everything else." },
  { q: "Where do you train?", a: "At Koh's 33 Stadium in Lamai and PSG Academy in Chaweng. The exact ground and weekly schedule are confirmed when you book, as sessions follow school terms and island weather." },
  { q: "Do you offer scholarships?", a: "Yes. Inclusion is a founding value — sponsored spots for local kids are funded by our partners and corporate events. Ask us on WhatsApp." },
];

const schema = [
  { "@context": "https://schema.org", "@type": "ContactPage", name: "Contact & Registration — Coconut Samui Rugby Academy", url: "https://coconutsamuirugby.com/contact/" },
  faqSchema(faq),
];

const schedule = [
  ["Kids · 4–10", "Saturday mornings"],
  ["Teens · 11–17", "Saturday mornings + midweek"],
  ["Adults touch", "Weekly sunset session"],
];
---

<Base
  title="Contact & Registration | Coconut Samui Rugby Academy"
  description="Register your child or join a session. Reach us by form, WhatsApp or email — we reply within 24 hours."
  schema={schema}
  whatsappMessage="Hi! I'd like to book a free trial session."
>
  <section class="mx-auto max-w-[1240px] px-5 pt-14 pb-6 sm:px-8 lg:pt-20">
    <div class="grid gap-x-16 gap-y-8 lg:grid-cols-12">
      <div class="lg:col-span-8" data-reveal>
        <p class="kicker">Contact &amp; Registration</p>
        <h1 class="display-xl mt-6">Book a free<br />trial session.</h1>
      </div>
      <p class="self-end text-lg leading-relaxed text-ink/70 lg:col-span-4" data-reveal data-reveal-delay="100ms">
        Fastest is WhatsApp. Prefer a form? It lands in the same inbox — we reply within 24 hours
        with the next session you can join.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-[1240px] px-5 py-14 sm:px-8">
    <div class="grid gap-12 lg:grid-cols-12">
      <!-- Form -->
      <form action={FORM_ENDPOINT} method="POST" class="lg:col-span-7" data-reveal>
        <input type="hidden" name="_subject" value="Trial / registration request — CSRA website" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_next" value={`${SITE.domain}/thanks/`} />
        <input type="text" name="_honey" class="hidden" style="display:none" tabindex="-1" aria-hidden="true" />

        <div class="grid gap-5 sm:grid-cols-2">
          <div class="sm:col-span-2">
            <label for="name" class="block text-sm font-medium">Your name</label>
            <input id="name" name="name" type="text" required autocomplete="name" class="mt-1.5 w-full rounded-md border border-ink/20 bg-paper px-4 py-3 text-sm focus:border-ink focus:outline-none" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium">Email</label>
            <input id="email" name="email" type="email" required autocomplete="email" class="mt-1.5 w-full rounded-md border border-ink/20 bg-paper px-4 py-3 text-sm focus:border-ink focus:outline-none" />
          </div>
          <div>
            <label for="child-age" class="block text-sm font-medium">Child's age <span class="font-normal text-ink/45">(if applicable)</span></label>
            <input id="child-age" name="child_age" type="text" inputmode="numeric" class="mt-1.5 w-full rounded-md border border-ink/20 bg-paper px-4 py-3 text-sm focus:border-ink focus:outline-none" />
          </div>
          <div class="sm:col-span-2">
            <label for="program" class="block text-sm font-medium">Program</label>
            <select id="program" name="program" required class="mt-1.5 w-full rounded-md border border-ink/20 bg-paper px-4 py-3 text-sm focus:border-ink focus:outline-none">
              <option value="">Choose one…</option>
              <option>Kids (4–10)</option>
              <option>Teens (11–17)</option>
              <option>Adults touch rugby</option>
              <option>Corporate team-building</option>
              <option>Camp / event</option>
              <option>Sponsorship</option>
            </select>
          </div>
          <div class="sm:col-span-2">
            <label for="message" class="block text-sm font-medium">Anything we should know?</label>
            <textarea id="message" name="message" rows="4" class="mt-1.5 w-full rounded-md border border-ink/20 bg-paper px-4 py-3 text-sm focus:border-ink focus:outline-none"></textarea>
          </div>
          <div class="sm:col-span-2">
            <button type="submit" data-analytics="trial-form-submit" class="group inline-flex w-full items-center justify-center gap-2.5 rounded-md bg-ink px-6 py-3.5 font-body text-[0.95rem] font-semibold text-paper transition-colors hover:bg-clay hover:text-chalk">
              Send — we reply within 24h
              <svg viewBox="0 0 24 24" class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </button>
          </div>
        </div>
      </form>

      <!-- Direct + practical -->
      <div class="space-y-6 lg:col-span-4 lg:col-start-9" data-reveal data-reveal-delay="100ms">
        <div class="relative overflow-hidden rounded-xl bg-ink p-7 text-paper grain">
          <div class="relative">
            <h2 class="font-display text-xl text-paper">Faster on WhatsApp</h2>
            <p class="mt-2 text-sm text-paper/75">One message with your child's age is enough.</p>
            <div class="mt-5"><Button href={waLink("Hi! I'd like to book a free trial session.")} variant="paper">Open WhatsApp</Button></div>
            <p class="mt-5 break-all text-sm text-paper/70">
              Or email <a href={`mailto:${SITE.email}`} class="link-underline text-paper">{SITE.email}</a><br />
              Instagram <a href={SITE.instagram} target="_blank" rel="noopener" class="link-underline text-paper">{SITE.instagramHandle}</a>
            </p>
          </div>
        </div>

        <div class="rounded-xl border border-ink/12 p-7">
          <h2 class="font-display text-xl">Where &amp; when</h2>
          <dl class="mt-4 divide-y divide-ink/10 text-sm">
            {
              schedule.map(([p, w]) => (
                <div class="flex items-center justify-between gap-4 py-2.5">
                  <dt class="font-medium text-ink/80">{p}</dt>
                  <dd class="text-ink/60">{w}</dd>
                </div>
              ))
            }
          </dl>
          <p class="mt-3 text-xs text-ink/50">Exact times confirmed on booking.</p>
          <div class="mt-5 space-y-2.5">
            {
              SITE.venues.map((v) => (
                <a href={v.mapsUrl} target="_blank" rel="noopener" class="link-underline inline-flex items-center gap-2 font-body text-sm font-semibold text-ink">
                  <svg viewBox="0 0 24 24" class="h-4 w-4 text-clay-deep" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 1 1 16 0Z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                  {v.name}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <div class="mt-16 grid gap-x-16 gap-y-8 lg:grid-cols-12">
      <div class="lg:col-span-4" data-reveal>
        <p class="kicker">Before you ask</p>
        <h2 class="display-lg mt-4">Quick answers</h2>
      </div>
      <div class="lg:col-span-7 lg:col-start-6" data-reveal data-reveal-delay="100ms"><FAQ items={faq} /></div>
    </div>
  </section>
</Base>
