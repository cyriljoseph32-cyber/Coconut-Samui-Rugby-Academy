---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
import PalmSilhouette from "../components/PalmSilhouette.astro";
import { waLink } from "../config/site";

const tiers = [
  { name: "Bronze", pitch: "Get behind the kids", perks: ["Logo on academy website", "Social thank-you posts", "Partnership certificate"] },
  { name: "Silver", pitch: "Be seen on match days", perks: ["Everything in Bronze", "Logo on training kit", "Banner at sessions & events", "Monthly social features"] },
  { name: "Gold", pitch: "On the jersey", perks: ["Everything in Silver", "Logo on match jerseys", "Branding at camps & tournaments", "Content collaboration"] },
  { name: "Platinum", pitch: "Naming rights", perks: ["Everything in Gold", "Front-of-jersey placement", "Naming rights: camp, team or tournament", "Dedicated PR launch moment"], featured: true },
];

const reach = [
  ["30+", "families in the community by 2027 — each a word-of-mouth channel"],
  ["3", "branded events in year one: two camps and the island's first tournament"],
  ["52", "weeks of social content a year — training, match days, island life"],
];
---

<Base
  title="Sponsorship & Partnership | Coconut Samui Rugby Academy"
  description="Bronze to Platinum sponsorship: jersey branding, event naming rights, social reach. Put your business behind Koh Samui's youth."
  whatsappMessage="Hi! I'd like the sponsorship deck for Coconut Samui Rugby Academy."
>
  <!-- Hero, ink -->
  <section class="relative overflow-hidden border-b border-ink/12 bg-ink text-paper">
    <PalmSilhouette class="pointer-events-none absolute -right-10 -bottom-16 h-96 w-96 text-fern/12" />
    <div class="relative mx-auto max-w-[1240px] px-5 pt-16 pb-20 sm:px-8">
      <div class="grid gap-x-16 gap-y-8 lg:grid-cols-12">
        <div class="lg:col-span-8" data-reveal>
          <p class="kicker text-clay">Partnership &amp; Sponsorship</p>
          <h1 class="display-xl mt-6 text-paper">Get your name<br />on the jersey.</h1>
        </div>
        <div class="self-end lg:col-span-4" data-reveal data-reveal-delay="100ms">
          <p class="text-lg leading-relaxed text-paper/75">
            Every jersey, camp and tournament on Samui will carry its founding partners' names — in
            front of expat families, schools, tourists and the island's business community.
          </p>
          <div class="mt-8"><Button href={waLink("Hi! Please send me the sponsorship deck.")} variant="paper">Request the deck</Button></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Reach -->
  <section class="mx-auto max-w-[1240px] px-5 py-20 sm:px-8">
    <div class="grid gap-x-16 gap-y-10 lg:grid-cols-12">
      <div class="lg:col-span-4" data-reveal>
        <p class="kicker">Why sponsor</p>
        <h2 class="display-lg mt-5">Visibility<br />with heart.</h2>
        <p class="mt-5 leading-relaxed text-ink/65">
          First-mover categories don't come around often. Rugby on Samui has one academy — and its
          partners own the story from day one.
        </p>
      </div>
      <dl class="grid gap-px overflow-hidden rounded-xl border border-ink/12 bg-ink/12 sm:grid-cols-3 lg:col-span-7 lg:col-start-6">
        {
          reach.map(([s, l], i) => (
            <div class="bg-paper p-8" data-reveal data-reveal-delay={`${i * 90}ms`}>
              <dt class="font-display text-5xl text-palm">{s}</dt>
              <dd class="mt-3 text-sm leading-relaxed text-ink/65">{l}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- Tiers -->
  <section class="border-t border-ink/12 bg-sand/40">
    <div class="mx-auto max-w-[1240px] px-5 py-20 sm:px-8">
      <h2 class="display-lg max-w-xl" data-reveal>Four ways in.</h2>
      <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        {
          tiers.map((tier, i) => (
            <div
              class={`flex flex-col rounded-xl p-7 grain ${tier.featured ? "bg-ink text-paper" : "border border-ink/12 bg-paper"}`}
              data-reveal
              data-reveal-delay={`${i * 70}ms`}
            >
              <div class="relative flex items-baseline justify-between">
                <h3 class={`font-display text-2xl ${tier.featured ? "text-clay" : "text-palm"}`}>{tier.name}</h3>
                <span class={`font-body text-xs font-semibold tabular-nums ${tier.featured ? "text-paper/50" : "text-ink/40"}`}>0{i + 1}</span>
              </div>
              <p class={`relative mt-1 text-sm font-medium ${tier.featured ? "text-paper/70" : "text-ink/55"}`}>{tier.pitch}</p>
              <ul class={`relative mt-6 flex-1 space-y-3 text-sm leading-relaxed ${tier.featured ? "text-paper/80" : "text-ink/75"}`}>
                {tier.perks.map((perk) => (
                  <li class="flex gap-2.5 border-t pt-3" style={`border-color:${tier.featured ? "oklch(0.99 0.006 92 / 0.15)" : "oklch(0.24 0.035 165 / 0.1)"}`}>
                    <svg viewBox="0 0 24 24" class={`mt-0.5 h-4 w-4 shrink-0 ${tier.featured ? "text-clay" : "text-clay-deep"}`} fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    {perk}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
      <p class="mt-8 max-w-2xl text-sm text-ink/55" data-reveal>
        Tier pricing is shared in the sponsorship deck — packages can be tailored, and in-kind
        partnerships (kit, venue, catering, transport) are welcome.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-[1240px] px-5 py-20 sm:px-8">
    <div class="grid items-end gap-8 lg:grid-cols-12">
      <div class="lg:col-span-8" data-reveal>
        <p class="kicker">Next step</p>
        <h2 class="display-lg mt-4">Fifteen minutes, one coffee.</h2>
        <p class="mt-5 max-w-xl leading-relaxed text-ink/70">
          Tell us about your business and we'll show you exactly where your brand fits — jersey, camp,
          tournament, or all three.
        </p>
      </div>
      <div class="flex flex-wrap gap-4 lg:col-span-4 lg:justify-end" data-reveal data-reveal-delay="100ms">
        <Button href={waLink("Hi! I'm interested in sponsoring the academy. Can we talk?")}>WhatsApp us</Button>
        <Button href="/contact/" variant="outline">Contact form</Button>
      </div>
    </div>
  </section>
</Base>
