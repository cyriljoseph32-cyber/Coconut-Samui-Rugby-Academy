---
import Base from "../layouts/Base.astro";
import Wave from "../components/Wave.astro";
import Button from "../components/Button.astro";
import SectionHead from "../components/SectionHead.astro";
import { eventSchema } from "../lib/schema";
import { waLink } from "../config/site";

// Update this list as camps are confirmed — each entry renders a card and Event schema.
const events = [
  {
    name: "Songkran Holiday Rugby Camp",
    dates: "April school holidays 2025 · dates TBC",
    startDate: "2025-04-14",
    endDate: "2025-04-18",
    ages: "Ages 6–16",
    desc: "Five mornings of skills, games and beach sessions. Split age groups, all levels, lunch included. Visiting families welcome.",
    status: "Registration opening soon",
  },
  {
    name: "Summer Intensive Camp",
    dates: "July–August 2025 · dates TBC",
    startDate: "2025-07-21",
    endDate: "2025-07-25",
    ages: "Ages 8–17",
    desc: "A full week to level up: position-specific skills, game understanding and a final tournament day with medals and a barbecue.",
    status: "Registration opening soon",
  },
  {
    name: "Koh Samui Inter-School Rugby Tournament",
    dates: "Late 2025 · date TBC",
    startDate: "2025-11-15",
    endDate: "2025-11-15",
    ages: "School teams, U11–U15",
    desc: "The island's first inter-school rugby tournament. One day, every school, one trophy — and the start of a Samui tradition.",
    status: "Schools: register interest now",
  },
];

const schema = events.map((e) =>
  eventSchema({ name: e.name, description: e.desc, startDate: e.startDate, endDate: e.endDate })
);
---

<Base
  title="Rugby Camps & Events Koh Samui | Holiday Camps for Kids & Teens"
  description="Intensive rugby camps during school holidays and Koh Samui's first inter-school tournament. Open to residents and visiting families."
  schema={schema}
  whatsappMessage="Hi! I'd like information about the next rugby camp."
>
  <section class="bg-shell">
    <div class="mx-auto max-w-[1200px] px-4 pb-14 pt-14 sm:px-6 lg:pt-20">
      <p class="font-display text-sm font-bold tracking-[0.25em] text-amber-dark uppercase">
        Camps &amp; Events
      </p>
      <h1 class="mt-3 text-4xl leading-tight text-palm sm:text-5xl">Rugby Camps &amp; Island Events</h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-jungle/80">
        School-holiday camps, match days and — coming soon — the island's first inter-school
        tournament. If you're visiting Samui with kids, camps are the fastest way to plug into
        island life.
      </p>
    </div>
  </section>
  <Wave fill="var(--color-shell)" flip />

  <section class="mx-auto max-w-[1200px] px-4 py-16 sm:px-6 lg:py-20">
    <SectionHead eyebrow="2025 calendar" title="Upcoming" />
    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {
        events.map((e) => (
          <article class="flex flex-col rounded-3xl border border-sand bg-white p-7 shadow-sm">
            <p class="font-display text-xs font-bold tracking-[0.2em] text-amber-dark uppercase">
              {e.dates}
            </p>
            <h2 class="mt-2 text-xl text-palm">{e.name}</h2>
            <p class="mt-1 text-sm font-semibold text-jungle/60">{e.ages}</p>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-jungle/80">{e.desc}</p>
            <p class="mt-4 inline-flex w-fit rounded-full bg-shell px-3.5 py-1.5 text-xs font-bold text-palm">
              {e.status}
            </p>
            <div class="mt-5">
              <Button
                href={waLink(`Hi! I'd like to reserve a spot for: ${e.name}`)}
                variant="secondary"
                class="w-full"
              >
                Reserve a spot
              </Button>
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-2">
      <div class="rounded-3xl bg-shell p-8">
        <h2 class="text-2xl text-palm">Visiting Samui with kids?</h2>
        <p class="mt-3 leading-relaxed text-jungle/80">
          Drop-in spots are available at weekly sessions and holiday camps. Your kids get a morning
          of sport and new friends; you get a beach morning. Everyone wins.
        </p>
        <div class="mt-5">
          <Button href={waLink("Hi! We're visiting Samui — can our kids drop in to a session or camp?")}>
            Ask about drop-ins
          </Button>
        </div>
      </div>
      <div class="rounded-3xl bg-jungle p-8 text-white">
        <h2 class="text-2xl">Schools &amp; teams</h2>
        <p class="mt-3 leading-relaxed text-sand">
          We partner with international and local schools for taster days, after-school programs
          and the inter-school tournament. Get your school on the pitch.
        </p>
        <div class="mt-5">
          <Button href="/contact/">Talk to us</Button>
        </div>
      </div>
    </div>
  </section>
</Base>
