---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
import { eventSchema } from "../lib/schema";
import { waLink } from "../config/site";

// Update as camps are confirmed — each entry renders a row and Event schema.
const events = [
  {
    name: "Songkran Holiday Rugby Camp",
    window: "April school holidays 2027",
    startDate: "2027-04-12",
    endDate: "2027-04-16",
    ages: "Ages 6–16",
    desc: "Five mornings of skills, games and beach sessions. Split age groups, all levels, lunch included. Visiting families welcome.",
    status: "Registration opening soon",
  },
  {
    name: "Summer Intensive Camp",
    window: "July–August 2027",
    startDate: "2027-07-19",
    endDate: "2027-07-23",
    ages: "Ages 8–17",
    desc: "A full week to level up: position-specific skills, game understanding and a final tournament day with medals and a barbecue.",
    status: "Registration opening soon",
  },
  {
    name: "Koh Samui Inter-School Rugby Tournament",
    window: "Late 2027",
    startDate: "2027-11-13",
    endDate: "2027-11-13",
    ages: "School teams · U11–U15",
    desc: "The island's first inter-school rugby tournament. One day, every school, one trophy — and the start of a Samui tradition.",
    status: "Schools: register interest now",
  },
];

const schema = events.map((e) =>
  eventSchema({ name: e.name, description: e.desc, startDate: e.startDate, endDate: e.endDate })
);
---

<Base
  title="Rugby Camps & Events Koh Samui | Holiday Camps for Kids & Teens"
  description="Intensive rugby camps during school holidays and Koh Samui's first inter-school tournament. Open to residents and visiting families."
  schema={schema}
  whatsappMessage="Hi! I'd like information about the next rugby camp."
>
  <section class="mx-auto max-w-[1240px] px-5 pt-14 pb-6 sm:px-8 lg:pt-20">
    <div class="grid gap-x-16 gap-y-8 lg:grid-cols-12">
      <div class="lg:col-span-8" data-reveal>
        <p class="kicker">Camps &amp; Events</p>
        <h1 class="display-xl mt-6">Holiday camps &amp;<br />island match days.</h1>
      </div>
      <p class="self-end text-lg leading-relaxed text-ink/70 lg:col-span-4" data-reveal data-reveal-delay="100ms">
        School-holiday camps, match days and the island's first inter-school tournament. Visiting
        Samui with kids? Camps are the fastest way in.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-[1240px] px-5 pb-16 sm:px-8">
    <div class="border-t border-ink/15">
      {
        events.map((e, i) => (
          <article class="grid gap-x-10 gap-y-4 border-b border-ink/15 py-9 lg:grid-cols-12" data-reveal>
            <div class="lg:col-span-3">
              <p class="font-body text-sm font-semibold text-clay-deep">{e.window}</p>
              <p class="mt-1 text-sm text-ink/55">{e.ages}</p>
            </div>
            <div class="lg:col-span-6">
              <h2 class="font-display text-2xl sm:text-3xl">{e.name}</h2>
              <p class="mt-2 max-w-xl leading-relaxed text-ink/70">{e.desc}</p>
              <p class="mt-3 inline-flex rounded-full border border-clay/40 bg-clay/10 px-3 py-1 text-xs font-semibold text-clay-deep">{e.status}</p>
            </div>
            <div class="flex items-start lg:col-span-3 lg:justify-end">
              <Button href={waLink(`Hi! I'd like to reserve a spot for: ${e.name}`)} variant="outline">Reserve a spot</Button>
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-2">
      <div class="rounded-xl border border-ink/12 bg-sand/50 p-8" data-reveal>
        <h2 class="font-display text-2xl">Visiting Samui with kids?</h2>
        <p class="mt-3 leading-relaxed text-ink/70">
          Drop-in spots run at weekly sessions and holiday camps. Your kids get a morning of sport
          and new friends; you get a beach morning. Everyone wins.
        </p>
        <div class="mt-6"><Button href={waLink("Hi! We're visiting Samui — can our kids drop in to a session or camp?")}>Ask about drop-ins</Button></div>
      </div>
      <div class="relative overflow-hidden rounded-xl bg-ink p-8 text-paper grain" data-reveal data-reveal-delay="100ms">
        <div class="relative">
          <h2 class="font-display text-2xl text-paper">Schools &amp; teams</h2>
          <p class="mt-3 leading-relaxed text-paper/75">
            We partner with international and local schools for taster days, after-school programs
            and the inter-school tournament. Get your school on the pitch.
          </p>
          <div class="mt-6"><Button href="/contact/" variant="paper">Talk to us</Button></div>
        </div>
      </div>
    </div>
  </section>
</Base>
