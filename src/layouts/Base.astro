---
import "@fontsource-variable/fraunces";
import "@fontsource-variable/schibsted-grotesk";
import "@fontsource/noto-sans-thai";
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import { SITE } from "../config/site";

interface Props {
  title: string;
  description: string;
  /** Extra JSON-LD blocks appended after the base Organization schema. */
  schema?: Record<string, unknown>[];
  whatsappMessage?: string;
}
const { title, description, schema = [], whatsappMessage } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);

const orgSchema = {
  "@context": "https://schema.org",
  "@type": ["SportsActivityLocation", "LocalBusiness"],
  name: SITE.name,
  url: SITE.domain,
  logo: `${SITE.domain}/favicon.svg`,
  email: SITE.email,
  sameAs: [SITE.instagram],
  address: {
    "@type": "PostalAddress",
    addressLocality: "Koh Samui",
    addressRegion: "Surat Thani",
    addressCountry: "TH",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: SITE.location.lat,
    longitude: SITE.location.lng,
  },
  sport: "Rugby",
};
const allSchema = [orgSchema, ...schema];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#0e5a3c" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />

    {allSchema.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}

    <!-- GA4: replace G-XXXXXXXXXX with the real measurement ID, then uncomment.
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
    -->
    <!-- Microsoft Clarity: paste the snippet from clarity.microsoft.com here before launch. -->
  </head>
  <body class="flex min-h-screen flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-clay focus:px-5 focus:py-2.5 focus:font-bold focus:text-chalk"
    >
      Skip to content
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton message={whatsappMessage} />

    <script>
      // Scroll-reveal — purposeful, subtle, and fully progressive (no JS = visible).
      const els = document.querySelectorAll("[data-reveal]");
      if (els.length && "IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                (e.target as HTMLElement).style.transitionDelay =
                  (e.target as HTMLElement).dataset.revealDelay || "0ms";
                e.target.classList.add("is-in");
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.08 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add("is-in"));
      }
    </script>
  </body>
</html>
