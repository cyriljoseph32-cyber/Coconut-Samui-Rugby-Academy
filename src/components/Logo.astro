---
/**
 * Logo lockups built on the refined LogoMark.
 *  - secondary → horizontal, for the header
 *  - primary   → stacked, for the footer / large moments
 *  - monogram  → ball crest with CSRA, for jerseys / avatars
 */
import LogoMark from "./LogoMark.astro";

interface Props {
  variant?: "primary" | "secondary" | "monogram";
  seam?: string;
  class?: string;
}
const { variant = "secondary", seam = "var(--color-paper)", class: className = "" } = Astro.props;
---

{
  variant === "secondary" && (
    <span class={`inline-flex items-center gap-2.5 ${className}`}>
      <LogoMark seam={seam} class="h-9 w-9 shrink-0" />
      <span class="font-display leading-[0.95]">
        <span class="block text-[0.98rem] font-semibold tracking-tight">Coconut Samui</span>
        <span class="mt-[1px] block font-body text-[0.6rem] font-semibold tracking-[0.32em] uppercase opacity-70">
          Rugby Academy
        </span>
      </span>
    </span>
  )
}

{
  variant === "primary" && (
    <span class={`inline-flex flex-col gap-3 ${className}`}>
      <LogoMark seam={seam} class="h-14 w-14" />
      <span class="font-display leading-[0.98]">
        <span class="block text-2xl font-semibold tracking-tight">Coconut Samui</span>
        <span class="mt-1 block font-body text-[0.66rem] font-semibold tracking-[0.34em] uppercase opacity-70">
          Rugby Academy
        </span>
      </span>
    </span>
  )
}

{
  variant === "monogram" && (
    <svg viewBox="0 0 80 100" class={className} fill="none" aria-hidden="true">
      <path
        d="M40 6C58 6 70 20 70 44C70 70 56 92 40 96C24 92 10 70 10 44C10 20 22 6 40 6Z"
        stroke="currentColor"
        stroke-width="3"
      />
      <path d="M40 40C39 33 41 26 38 20" stroke="currentColor" stroke-width="3.6" stroke-linecap="round" />
      <path d="M38 21C32 17 25 17 20 22" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" />
      <path d="M38 21C41 15 48 13 55 16" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" />
      <path d="M38 21C45 18 53 19 59 25" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" />
      <circle cx="34" cy="26" r="2.2" fill="currentColor" />
      <circle cx="42" cy="27" r="2.2" fill="currentColor" />
      <ellipse cx="40" cy="58" rx="11" ry="14" fill="currentColor" />
      <path d="M40 48V68M35 54H45M35 60H45" stroke="var(--color-paper)" stroke-width="1.8" stroke-linecap="round" />
      <text
        x="40"
        y="90"
        text-anchor="middle"
        fill="currentColor"
        font-family="'Schibsted Grotesk Variable', sans-serif"
        font-weight="700"
        font-size="12"
        letter-spacing="5"
      >
        CSRA
      </text>
    </svg>
  )
}
