---
import Logo from "./Logo.astro";
import PalmSilhouette from "./PalmSilhouette.astro";
import { SITE, FORM_ENDPOINT, waLink } from "../config/site";

const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden bg-ink text-paper">
  <PalmSilhouette class="pointer-events-none absolute -bottom-6 -right-10 h-72 w-72 text-fern/15 sm:h-96 sm:w-96" />

  <div class="relative mx-auto max-w-[1240px] px-5 pt-16 pb-10 sm:px-8">
    <div class="grid gap-12 md:grid-cols-[1.4fr_1fr_1fr]">
      <div>
        <a href="/" class="inline-block text-paper" aria-label="Coconut Samui Rugby Academy — home">
          <Logo variant="primary" />
        </a>
        <p class="mt-6 max-w-xs text-[0.95rem] leading-relaxed text-paper/70">
          Koh Samui's first structured rugby academy. Respect, discipline, inclusion, team spirit —
          for every kid on the island.
        </p>
      </div>

      <nav aria-label="Footer">
        <h2 class="kicker text-clay">Explore</h2>
        <ul class="mt-5 space-y-3 text-[0.95rem]">
          <li><a class="link-underline text-paper/80 hover:text-paper" href="/about/">About &amp; Mission</a></li>
          <li><a class="link-underline text-paper/80 hover:text-paper" href="/programs/">Programs</a></li>
          <li><a class="link-underline text-paper/80 hover:text-paper" href="/camps-events/">Camps &amp; Events</a></li>
          <li><a class="link-underline text-paper/80 hover:text-paper" href="/sponsorship/">Sponsorship</a></li>
          <li><a class="link-underline text-paper/80 hover:text-paper" href="/gallery/">Gallery</a></li>
          <li><a class="link-underline text-paper/80 hover:text-paper" href="/contact/">Contact</a></li>
        </ul>
      </nav>

      <div>
        <h2 class="kicker text-clay">Get in touch</h2>
        <ul class="mt-5 space-y-3 text-[0.95rem]">
          <li><a class="link-underline text-paper/80 hover:text-paper" href={waLink("Hi! I'd like to know more about the academy.")} target="_blank" rel="noopener">WhatsApp</a></li>
          <li><a class="link-underline break-all text-paper/80 hover:text-paper" href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
          <li><a class="link-underline text-paper/80 hover:text-paper" href={SITE.instagram} target="_blank" rel="noopener">Instagram {SITE.instagramHandle}</a></li>
          {
            SITE.venues.map((v) => (
              <li>
                <a class="link-underline text-paper/80 hover:text-paper" href={v.mapsUrl} target="_blank" rel="noopener">
                  {v.name}
                </a>
              </li>
            ))
          }
        </ul>

        <form action={FORM_ENDPOINT} method="POST" class="mt-7" aria-label="Newsletter signup">
          <input type="hidden" name="_subject" value="Newsletter signup — CSRA website" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value={`${SITE.domain}/thanks/`} />
          <input type="text" name="_honey" class="hidden" style="display:none" tabindex="-1" aria-hidden="true" />
          <label for="newsletter-email" class="block text-sm font-medium text-paper/80">Island news &amp; match days</label>
          <div class="mt-2 flex overflow-hidden rounded-md border border-paper/25 focus-within:border-clay">
            <input id="newsletter-email" type="email" name="email" required placeholder="you@email.com"
              class="w-full bg-transparent px-3.5 py-2.5 text-sm text-paper placeholder:text-paper/40 focus:outline-none" />
            <button type="submit" class="shrink-0 bg-clay px-4 font-body text-sm font-semibold text-chalk hover:bg-clay-deep" aria-label="Join newsletter">Join</button>
          </div>
        </form>
      </div>
    </div>

    <div class="mt-14 flex flex-col gap-2 border-t border-paper/12 pt-6 text-xs text-paper/50 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} Coconut Samui Rugby Academy · Koh Samui, Thailand</p>
      <p class="font-display italic text-paper/60">Fun, teamwork &amp; rugby in paradise.</p>
    </div>
  </div>
</footer>
