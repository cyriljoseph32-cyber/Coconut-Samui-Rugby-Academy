---
import type { FaqItem } from "../lib/schema";

interface Props {
  items: FaqItem[];
  class?: string;
}
const { items, class: className = "" } = Astro.props;
---

<div class={`border-t border-ink/12 ${className}`}>
  {
    items.map((item) => (
      <details class="group border-b border-ink/12">
        <summary class="flex cursor-pointer list-none items-start justify-between gap-6 py-5 [&::-webkit-details-marker]:hidden">
          <span class="font-display text-lg leading-snug text-ink">{item.q}</span>
          <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-ink/25 text-ink transition-colors group-open:bg-ink group-open:text-paper">
            <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
              <path d="M12 5v14M5 12h14" />
            </svg>
          </span>
        </summary>
        <p class="max-w-2xl pb-6 leading-relaxed text-ink/70">{item.a}</p>
      </details>
    ))
  }
</div>
