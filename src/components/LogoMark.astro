---
/**
 * "Palm Lineout" mark, refined: a rugby ball on its point whose seam becomes a
 * palm trunk, three fronds arcing off the top, two coconuts. Chunky strokes and
 * solid ball so it survives embroidery and 16px favicons. Single colour via
 * currentColor; `seam` tints the ball's lacing/negative detail.
 */
interface Props {
  seam?: string;
  class?: string;
}
const { seam = "var(--color-paper)", class: className = "" } = Astro.props;
---

<svg viewBox="0 0 64 64" class={className} fill="none" aria-hidden="true">
  <!-- ball, upright -->
  <ellipse cx="32" cy="42" rx="15" ry="19" fill="currentColor"></ellipse>
  <!-- lacing seam -->
  <path d="M32 30V54" stroke={seam} stroke-width="2.4" stroke-linecap="round"></path>
  <path d="M28 36H36M28 42H36M28 48H36" stroke={seam} stroke-width="2.2" stroke-linecap="round"></path>
  <!-- palm trunk rising from the ball's tip -->
  <path d="M32 24C31 18 33 12 30 6" stroke="currentColor" stroke-width="4.4" stroke-linecap="round"></path>
  <!-- fronds -->
  <path d="M30 7C24 3 17 3 12 8" stroke="currentColor" stroke-width="4" stroke-linecap="round"></path>
  <path d="M30 7C33 1 40 -1 47 2" stroke="currentColor" stroke-width="4" stroke-linecap="round"></path>
  <path d="M30 7C37 4 45 5 51 11" stroke="currentColor" stroke-width="4" stroke-linecap="round"></path>
  <!-- coconuts -->
  <circle cx="26" cy="12" r="2.6" fill="currentColor"></circle>
  <circle cx="34" cy="13" r="2.6" fill="currentColor"></circle>
</svg>
