---
/** Flat two-tone island scene: pitch, goal posts, palms, sea. Placeholder until real photography. */
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg viewBox="0 0 560 420" class={className} fill="none" role="img" aria-label="Illustration of a rugby pitch by the sea on Koh Samui, with palm trees and goal posts">
  <!-- sky -->
  <rect width="560" height="420" rx="24" fill="#f8f4ea"></rect>
  <!-- sun -->
  <circle cx="430" cy="88" r="42" fill="#f4a340"></circle>
  <!-- sea -->
  <path d="M0 218C90 200 190 200 280 214C370 228 470 228 560 210V300H0V218Z" fill="#bcd6c8"></path>
  <!-- beach -->
  <path d="M0 268C120 250 240 254 340 268C440 282 520 280 560 270V330H0V268Z" fill="#e8dcc4"></path>
  <!-- pitch -->
  <path d="M0 310C140 292 300 292 560 314V420H0V310Z" fill="#0e5a3c"></path>
  <path d="M0 340C160 324 340 324 560 344" stroke="#167a52" stroke-width="5" stroke-linecap="round"></path>
  <path d="M0 376C160 360 340 360 560 380" stroke="#167a52" stroke-width="5" stroke-linecap="round"></path>
  <!-- goal posts -->
  <g stroke="#ffffff" stroke-width="9" stroke-linecap="round">
    <path d="M395 330V216"></path>
    <path d="M465 334V220"></path>
    <path d="M395 268H465"></path>
  </g>
  <!-- rugby ball mid-flight -->
  <ellipse cx="330" cy="196" rx="26" ry="15" transform="rotate(-20 330 196)" fill="#123028"></ellipse>
  <path d="M312 202L348 190" stroke="#e8dcc4" stroke-width="3" stroke-linecap="round"></path>
  <!-- big palm -->
  <g stroke="#123028" stroke-linecap="round">
    <path d="M96 336C100 296 102 258 122 220" stroke-width="13"></path>
    <path d="M122 220C100 208 78 208 58 220" stroke-width="11"></path>
    <path d="M122 220C104 200 84 194 64 198" stroke-width="11"></path>
    <path d="M122 220C120 196 128 178 146 168" stroke-width="11"></path>
    <path d="M122 220C144 198 166 192 186 196" stroke-width="11"></path>
    <path d="M122 220C144 212 168 214 186 228" stroke-width="11"></path>
  </g>
  <circle cx="110" cy="232" r="8" fill="#123028"></circle>
  <circle cx="132" cy="235" r="8" fill="#123028"></circle>
  <!-- small palm -->
  <g stroke="#0e5a3c" stroke-linecap="round">
    <path d="M210 330C212 306 212 286 224 262" stroke-width="9"></path>
    <path d="M224 262C210 254 196 254 184 262" stroke-width="7"></path>
    <path d="M224 262C212 250 198 246 186 248" stroke-width="7"></path>
    <path d="M224 262C224 246 230 234 242 228" stroke-width="7"></path>
    <path d="M224 262C238 248 252 244 264 246" stroke-width="7"></path>
    <path d="M224 262C238 258 254 260 266 268" stroke-width="7"></path>
  </g>
</svg>
