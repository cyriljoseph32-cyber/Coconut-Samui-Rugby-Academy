---
import Logo from "./Logo.astro";

const nav = [
  { href: "/about/", label: "About" },
  { href: "/programs/", label: "Programs" },
  { href: "/camps-events/", label: "Camps & Events" },
  { href: "/sponsorship/", label: "Sponsorship" },
  { href: "/gallery/", label: "Gallery" },
];
const current = Astro.url.pathname;
---

<header class="sticky top-0 z-40 border-b border-sand bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-[1200px] items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="text-palm" aria-label="Coconut Samui Rugby Academy — home">
      <Logo variant="secondary" accent="#f4a340" />
    </a>

    <nav class="hidden items-center gap-6 lg:flex" aria-label="Main">
      {
        nav.map((item) => (
          <a
            href={item.href}
            aria-current={current === item.href ? "page" : undefined}
            class={`font-display text-sm font-semibold transition-colors hover:text-palm ${
              current === item.href ? "text-palm underline underline-offset-8" : "text-jungle"
            }`}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/contact/"
        class="rounded-full bg-amber px-5 py-2.5 font-display text-sm font-bold text-jungle transition-colors hover:bg-amber-dark hover:text-white"
      >
        Book a Free Trial
      </a>
    </nav>

    <button
      id="menu-toggle"
      class="flex h-11 w-11 items-center justify-center rounded-lg text-palm lg:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16"></path>
      </svg>
    </button>
  </div>

  <nav id="mobile-menu" class="hidden border-t border-sand bg-white px-4 pb-6 pt-2 lg:hidden" aria-label="Mobile">
    {
      nav.map((item) => (
        <a
          href={item.href}
          aria-current={current === item.href ? "page" : undefined}
          class="block border-b border-shell py-3.5 font-display font-semibold text-jungle"
        >
          {item.label}
        </a>
      ))
    }
    <a
      href="/contact/"
      class="mt-4 block rounded-full bg-amber px-5 py-3 text-center font-display font-bold text-jungle"
    >
      Book a Free Trial
    </a>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
  });
</script>
