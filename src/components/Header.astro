---
import Logo from "./Logo.astro";

const nav = [
  { href: "/about/", label: "About" },
  { href: "/programs/", label: "Programs" },
  { href: "/camps-events/", label: "Camps" },
  { href: "/sponsorship/", label: "Sponsor" },
  { href: "/gallery/", label: "Gallery" },
];
const current = Astro.url.pathname;
const isActive = (href: string) => current === href || (href !== "/" && current.startsWith(href));
---

<header class="sticky top-0 z-40 border-b border-ink/10 bg-paper/85 backdrop-blur-md">
  <div class="mx-auto flex max-w-[1240px] items-center justify-between gap-6 px-5 py-3.5 sm:px-8">
    <a href="/" class="text-ink" aria-label="Coconut Samui Rugby Academy — home">
      <Logo variant="secondary" seam="var(--color-paper)" />
    </a>

    <nav class="hidden items-center gap-8 lg:flex" aria-label="Main">
      {
        nav.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
            class={`link-underline font-body text-sm font-medium ${
              isActive(item.href) ? "text-clay-deep" : "text-ink/80 hover:text-ink"
            }`}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/contact/"
        class="rounded-md bg-ink px-5 py-2.5 font-body text-sm font-semibold text-paper transition-colors hover:bg-clay hover:text-chalk"
      >
        Free trial
      </a>
    </nav>

    <button
      id="menu-toggle"
      class="flex h-11 w-11 items-center justify-center rounded-md text-ink lg:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M4 8h16M4 16h16"></path>
      </svg>
    </button>
  </div>

  <nav id="mobile-menu" class="hidden border-t border-ink/10 bg-paper px-5 pb-6 pt-2 lg:hidden" aria-label="Mobile">
    {
      nav.map((item) => (
        <a
          href={item.href}
          aria-current={isActive(item.href) ? "page" : undefined}
          class="flex items-center justify-between border-b border-ink/8 py-4 font-display text-lg text-ink"
        >
          {item.label}
          <svg viewBox="0 0 24 24" class="h-4 w-4 text-ink/40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 6l6 6-6 6"/></svg>
        </a>
      ))
    }
    <a href="/contact/" class="mt-5 block rounded-md bg-ink px-5 py-3.5 text-center font-body font-semibold text-paper">
      Book a free trial
    </a>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
  });
</script>
