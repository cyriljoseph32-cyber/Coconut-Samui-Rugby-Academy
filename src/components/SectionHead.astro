---
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  align?: "left" | "center";
  class?: string;
  index?: string;
}
const { eyebrow, title, lede, align = "left", class: className = "", index } = Astro.props;
---

<div class={`${align === "center" ? "mx-auto max-w-2xl text-center" : "max-w-2xl"} ${className}`} data-reveal>
  <div class={`flex items-baseline gap-3 ${align === "center" ? "justify-center" : ""}`}>
    {index && <span class="font-body text-sm font-semibold text-clay-deep tabular-nums">{index}</span>}
    {eyebrow && <p class="kicker">{eyebrow}</p>}
  </div>
  <h2 class="display-lg mt-4">{title}</h2>
  {lede && <p class="mt-5 text-lg leading-relaxed text-ink/70">{lede}</p>}
</div>
