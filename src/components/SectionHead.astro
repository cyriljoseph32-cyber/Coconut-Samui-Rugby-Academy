---
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  align?: "left" | "center";
  class?: string;
}
const { eyebrow, title, lede, align = "center", class: className = "" } = Astro.props;
---

<div class={`max-w-2xl ${align === "center" ? "mx-auto text-center" : ""} ${className}`}>
  {eyebrow && (
    <p class="font-display text-sm font-bold tracking-[0.25em] text-amber-dark uppercase">{eyebrow}</p>
  )}
  <h2 class="mt-2 text-3xl text-palm sm:text-4xl">{title}</h2>
  {lede && <p class="mt-4 text-lg leading-relaxed text-jungle/80">{lede}</p>}
</div>
